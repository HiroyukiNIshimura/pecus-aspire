{
  "name": "@coati/editor",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./nodes": {
      "types": "./dist/nodes.d.ts",
      "import": "./dist/nodes.mjs",
      "require": "./dist/nodes.js"
    },
    "./nodes-headless": {
      "types": "./dist/nodes-headless.d.ts",
      "import": "./dist/nodes-headless.mjs",
      "require": "./dist/nodes-headless.js"
    },
    "./transformers": {
      "types": "./dist/transformers.d.ts",
      "import": "./dist/transformers.mjs",
      "require": "./dist/transformers.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check --write",
    "format": "biome format --write",
    "update:check": "ncu",
    "update": "ncu -u"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@lexical/clipboard": "0.45.0",
    "@lexical/code": "0.45.0",
    "@lexical/code-shiki": "0.45.0",
    "@lexical/extension": "0.45.0",
    "@lexical/file": "0.45.0",
    "@lexical/hashtag": "0.45.0",
    "@lexical/html": "0.45.0",
    "@lexical/link": "0.45.0",
    "@lexical/list": "0.45.0",
    "@lexical/mark": "0.45.0",
    "@lexical/markdown": "0.45.0",
    "@lexical/overflow": "0.45.0",
    "@lexical/plain-text": "0.45.0",
    "@lexical/react": "0.45.0",
    "@lexical/rich-text": "0.45.0",
    "@lexical/selection": "0.45.0",
    "@lexical/table": "0.45.0",
    "@lexical/tailwind": "0.45.0",
    "@lexical/utils": "0.45.0",
    "date-fns": "^4.4.0",
    "katex": "^0.17.0",
    "lexical": "0.45.0",
    "mermaid": "^11.15.0",
    "react-day-picker": "^10.0.1",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "npm-check-updates": "^22.2.3"
  }
}
