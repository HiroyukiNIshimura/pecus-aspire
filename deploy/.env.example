# このディレクトリの docker compose 用（例）
# 実運用では config/settings.base.prod.json の生成物 deploy/.env を流用する運用でもOK。

# 必須: 永続データ保存先
DATA_PATH=/var/lib/coati

# PostgreSQL
POSTGRES_USER=pecus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=pecusdb

# 公開URL（.NET/Nextの内部設定で参照される）
FRONTEND_URL=https://your-domain.example
NEXT_PUBLIC_API_URL=https://your-domain.example/backend

# 任意: Nginx公開ポート
NGINX_HTTP_PORT=80

# 任意: 内部URL
LEXICAL_CONVERTER_URL=http://lexicalconverter:5100
REDIS_URL=redis://redis-frontend:6379

# 任意: Postgres バックアップ
BACKUP_KEEP_DAYS=14

# 任意: 監視用ディスクマウントポイント（カンマ区切り）
# クラウド環境でデータボリュームが別の場合は追加
DISK_MOUNT_POINTS=/,/var/lib/coati

# コンテナ実行ユーザー（デフォルト: 1001）
# ホスト側の coati ユーザーの UID/GID に合わせる（id coati で確認）
CONTAINER_UID=1001
CONTAINER_GID=1001
